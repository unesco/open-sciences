htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*,cover

# Translations
*.mo
*.pot

# Kind cluster configuration with secrets
# OpenScience Tools config
openscience_tools/config/.env
openscience_tools/config/.env.kind

# Django stuff:
*.log

# Sphinx documentation
docs/_build/

# PyBuilder
target/

test.db

# Environments
.venv/

# Logs
logs/

# Invenio-cli per machine file
.invenio.private

# S3 default bucket location
data/default/*
data/.minio.sys

# Celery
celerybeat-schedule

# SSL certificates and keys
*.crt
*.key
*.pem

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Docker related
docker-compose.override.yml
.docker/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Local environment files
# Template:  deploy/.env.example (committed, has placeholders)
# Instances: deploy/.env.local, .env.staging, .env.production (ignored, contain secrets)
.env*
!deploy/.env.example

# Secret-scanning artefacts (contain real leaked values — never commit)
gitleaks-report.json
replacements.txt

# Generated configuration files (from templates)
invenio.cfg

# Kubernetes secrets (NEVER COMMIT!)
.k8s-secrets
k8s/values-production.local.yaml
k8s/secrets/

private/*

# Backups (contain sensitive data)
backups/
*.bak