# ==============================================================================
# UNESCO Open Science Portal - k3s Deployment Environment Variables
# ==============================================================================
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#   chmod 600 .env
#
# ⚠️ NEVER commit .env to version control!
# ==============================================================================

# ------------------------------------------------------------------------------
# Domain & TLS
# ------------------------------------------------------------------------------

# The domain name for the portal (e.g., open-science-dev.unesco.org)
DOMAIN=open-science-dev.unesco.org

# Email for Let's Encrypt certificate notifications
LETSENCRYPT_EMAIL=admin@unesco.org

# TLS mode: letsencrypt, selfsigned, or none
TLS_MODE=letsencrypt

# ------------------------------------------------------------------------------
# InvenioRDM Application
# ------------------------------------------------------------------------------

# Flask secret key (generate with: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Security login salt (generate with: openssl rand -hex 32)
SECURITY_LOGIN_SALT=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Admin email recipient for system alerts
ADMIN_EMAIL=admin.unix@unesco.org

# Initial admin user credentials
ADMIN_USER_EMAIL=admin@unesco.org
ADMIN_USER_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ------------------------------------------------------------------------------
# PostgreSQL Database
# ------------------------------------------------------------------------------

POSTGRES_USER=unesco_rdm
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=unesco_rdm

# ------------------------------------------------------------------------------
# RabbitMQ Message Queue
# ------------------------------------------------------------------------------

RABBITMQ_USER=invenio
RABBITMQ_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ------------------------------------------------------------------------------
# Docker Image
# ------------------------------------------------------------------------------

# Registry where the InvenioRDM image is stored
# If using GitLab CI/CD, this is typically: registry.example.org/group/project
DOCKER_REGISTRY=registry.example.org/sc/sc-openscience
DOCKER_IMAGE_TAG=latest

# Registry credentials (if private registry)
REGISTRY_USER=
REGISTRY_PASSWORD=

# ------------------------------------------------------------------------------
# SMTP Configuration (Email)
# ------------------------------------------------------------------------------

MAIL_SERVER=smtp.unesco.org
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@unesco.org

# ------------------------------------------------------------------------------
# Backup Configuration
# ------------------------------------------------------------------------------

# Directory on the host for storing backups
BACKUP_DIR=/opt/backups/unesco-rdm

# Number of daily backups to retain
BACKUP_RETENTION_DAYS=30

# Backup schedule (cron format) - default: daily at 2:00 AM
BACKUP_SCHEDULE="0 2 * * *"

# ------------------------------------------------------------------------------
# Resources (adjust based on VM specs)
# ------------------------------------------------------------------------------

# Minimum VM recommendation: 4 CPU, 8GB RAM, 50GB disk
# Recommended: 8 CPU, 16GB RAM, 100GB disk

# Web pods
WEB_REPLICAS=2
WEB_MEMORY_REQUEST=1Gi
WEB_MEMORY_LIMIT=2Gi
WEB_CPU_REQUEST=500m
WEB_CPU_LIMIT=1000m

# Worker pods
WORKER_REPLICAS=2
WORKER_MEMORY_REQUEST=512Mi
WORKER_MEMORY_LIMIT=1Gi
WORKER_CPU_REQUEST=250m
WORKER_CPU_LIMIT=500m
