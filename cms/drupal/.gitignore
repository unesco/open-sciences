# Ignore Drupal's file directory
/web/sites/*/files/*
!/web/sites/*/files/migrate/
/private/
/tmp/
/web/sites/*/private
/web/sites/*/tmp

# Ignore SimpleTest multi-site environment.
/web/sites/simpletest

# Ignore files generated by PhpStorm
/.idea/

# Ignore .env files as they are personal
/.env

# Ignore code editor files
/web/.vscode/

/web/test.php

/web/sync
/vendor/

# Ignore SimpleTest multi-site environment.
/web/sites/simpletest

# Ignore directories generated by Composer
/drush/contrib/
/vendor/
/web/core/
/web/libraries/
/web/modules/contrib/
/web/themes/contrib/
/web/themes/custom/*/node_modules/
/web/sites/*/themes/custom/*/node_modules/
/web/sites/*/themes/custom/*/css/style.css
/web/themes/custom/ctbto/css/style.css
/web/themes/custom/lac/css/style.css
/web/profiles/contrib/

