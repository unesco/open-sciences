+   *
+   * @return mixed
+   *   The sanitized alias when the alias is a string. Otherwise, the unmodified
+   *   alias.
+   */
+  public static function sanitizeAlias(mixed $alias, int $maxlength = 60): mixed {
+    if (!is_string($alias)) {
+      return $alias;
+    }
+    if (strlen($alias) > $maxlength) {
+      $checksum = 'c' . crc32($alias);
+      $pos = strlen($checksum) + strlen($alias) - $maxlength;
+      $alias = $checksum . substr($alias, $pos);
+    }
+    return strtolower(substr($alias, 0, $maxlength));
+  }
