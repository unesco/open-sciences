<?php

/**
 * @file
 * OpenSearch configuration and hooks for survey response word cloud.
 */

use Drupal\search_api\Entity\Server;
use Drupal\search_api\Entity\Index;

/**
 * Implements hook_install().
 */
function open_science_survey_search_install() {
  // Configure OpenSearch analyzer on module installation.
  _open_science_survey_search_configure_analyzer();
}

/**
 * Implements hook_search_api_index_load().
 */
function open_science_survey_search_search_api_index_load(array $indexes) {
  foreach ($indexes as $index) {
    if ($index->id() === 'survey_responses' && $index->status()) {
      _open_science_survey_search_configure_analyzer();
    }
  }
}

/**
 * Implements hook_search_api_index_update().
 */
function open_science_survey_search_search_api_index_update(\Drupal\search_api\IndexInterface $index) {
  if ($index->id() === 'survey_responses') {
    _open_science_survey_search_configure_analyzer();
  }
}

/**
 * Implements hook_ENTITY_TYPE_insert() for search_api_index.
 */
function open_science_survey_search_search_api_index_insert(\Drupal\search_api\IndexInterface $index) {
  if ($index->id() === 'survey_responses') {
    _open_science_survey_search_configure_analyzer();
  }
}

/**
 * Implements hook_search_api_index_reindex().
 */
function open_science_survey_search_search_api_index_reindex(\Drupal\search_api\IndexInterface $index, $clear = FALSE) {
  if ($index->id() === 'survey_responses') {
    _open_science_survey_search_configure_analyzer();
  }
}

/**
 * Implements hook_search_api_index_items_alter().
 */
function open_science_survey_search_search_api_index_items_alter(\Drupal\search_api\IndexInterface $index, array &$items) {
  // Ensure analyzer is configured before indexing starts.
  if ($index->id() === 'survey_responses') {
    static $configured = FALSE;
    if (!$configured) {
      _open_science_survey_search_configure_analyzer();
      $configured = TRUE;
    }
  }
}

/**
 * Implements hook_cron().
 */
function open_science_survey_search_cron() {
  // Ensure analyzer stays configured.
  $last_check = \Drupal::state()->get('open_science_survey_search.last_analyzer_check', 0);
  $now = \Drupal::time()->getRequestTime();
  
  // Check every hour.
  if ($now - $last_check > 3600) {
    _open_science_survey_search_configure_analyzer();
    \Drupal::state()->set('open_science_survey_search.last_analyzer_check', $now);
  }
}

/**
 * Configure custom OpenSearch analyzer with stop words and stemming.
 */
function _open_science_survey_search_configure_analyzer() {
  $logger = \Drupal::logger('open_science_survey_search');
  $logger->info('=== Starting analyzer configuration ===');
  
  try {
    /** @var \Drupal\search_api\ServerInterface $server */
    $server = Server::load('open_search');
    
    if (!$server) {
      $logger->error('OpenSearch server "open_search" not found.');
      return;
    }
    $logger->info('Server loaded successfully.');

    /** @var \Drupal\search_api_opensearch\Plugin\search_api\backend\SearchApiOpensearchBackend $backend */
    $backend = $server->getBackend();
    $logger->info('Backend retrieved: @class', ['@class' => get_class($backend)]);
    
    // Get OpenSearch client.
    $client = $backend->getClient();
    $logger->info('Client retrieved: @class', ['@class' => get_class($client)]);
    
    // Get configuration.
    $config = \Drupal::config('open_science_survey_search.settings');
    $stop_words_text = $config->get('stop_words') ?? '';
    $stop_words = array_filter(array_map('trim', explode("\n", $stop_words_text)));
    $logger->info('Loaded @count stop words', ['@count' => count($stop_words)]);
    
    // Get index name with prefix.
    $backend_config = $server->getBackendConfig();
    $prefix = $backend_config['advanced']['prefix'] ?? '';
    $index_name = $prefix . 'survey_responses';
    $logger->info('Target index name: @index', ['@index' => $index_name]);
    
    // Check if index exists.
    $index_exists = $client->indices()->exists(['index' => $index_name]);
    $logger->info('Index exists: @exists', ['@exists' => $index_exists ? 'YES' : 'NO']);
    
    if (!$index_exists) {
      $logger->info('Index does not exist. Creating it with custom analyzer...');
      
      // Create index with analyzer settings and mapping.
      $index_body = [
        'settings' => [
          'analysis' => [
            'analyzer' => [
              'custom_text_analyzer' => [
                'type' => 'custom',
                'tokenizer' => 'standard',
                'filter' => ['lowercase', 'custom_stop', 'porter_stem', 'asciifolding'],
              ],
              'wordcloud_analyzer' => [
                'type' => 'custom',
                'tokenizer' => 'standard',
                'filter' => ['lowercase', 'custom_stop', 'asciifolding'],
              ],
            ],
            'filter' => [
              'custom_stop' => [
                'type' => 'stop',
                'stopwords' => $stop_words,
              ],
            ],
          ],
        ],
        'mappings' => [
          'properties' => [
            'answer_open_text' => [
              'type' => 'text',
              'analyzer' => 'custom_text_analyzer',
              'fielddata' => TRUE,
              'fields' => [
                'keyword' => [
                  'type' => 'keyword',
                  'ignore_above' => 256,
                ],
                'wordcloud' => [
                  'type' => 'text',
                  'analyzer' => 'wordcloud_analyzer',
                  'fielddata' => TRUE,
                ],
              ],
            ],
          ],
        ],
      ];
      
      $create_response = $client->indices()->create([
        'index' => $index_name,
        'body' => $index_body,
      ]);
      
      $logger->info('Index created with custom analyzer: @response', ['@response' => json_encode($create_response)]);
      
      // Verify the configuration.
      try {
        $created_settings = $client->indices()->getSettings(['index' => $index_name]);
        $logger->info('Created index settings: @settings', ['@settings' => json_encode($created_settings)]);
        
        $created_mapping = $client->indices()->getMapping(['index' => $index_name]);
        $logger->info('Created index mapping: @mapping', ['@mapping' => json_encode($created_mapping)]);
      } catch (\Exception $e) {
        $logger->warning('Could not verify created settings: @msg', ['@msg' => $e->getMessage()]);
      }
      
      $logger->info('=== Analyzer configuration completed successfully ===');
      return;
    }
    
    // Get current mapping to check if analyzer is already configured.
    try {
      $current_mapping = $client->indices()->getMapping(['index' => $index_name]);
      $answer_open_text_field = $current_mapping[$index_name]['mappings']['properties']['answer_open_text'] ?? [];
      $current_analyzer = $answer_open_text_field['analyzer'] ?? null;
      $current_fielddata = $answer_open_text_field['fielddata'] ?? false;
      
      $logger->info('Current answer_open_text analyzer: @analyzer, fielddata: @fielddata', [
        '@analyzer' => $current_analyzer ?? 'none',
        '@fielddata' => $current_fielddata ? 'true' : 'false',
      ]);
      
      // If analyzer is already custom_text_analyzer and fielddata is true, we're done.
      if ($current_analyzer === 'custom_text_analyzer' && $current_fielddata) {
        $logger->info('Analyzer and fielddata already configured correctly.');
        return;
      }
      
      // If analyzer is wrong, we need to recreate the index.
      if ($current_analyzer && $current_analyzer !== 'custom_text_analyzer') {
        $logger->warning('Cannot change analyzer from @old to custom_text_analyzer. Index must be recreated.', [
          '@old' => $current_analyzer,
        ]);
        $logger->info('To fix: Delete index and run update_analyzer again: curl -X DELETE http://localhost:9200/@index', [
          '@index' => $index_name,
        ]);
        return;
      }
    } catch (\Exception $e) {
      $logger->warning('Could not retrieve current mapping: @msg', ['@msg' => $e->getMessage()]);
    }
    
    // Define custom analyzer settings.
    $settings = [
      'analysis' => [
        'analyzer' => [
          'custom_text_analyzer' => [
            'type' => 'custom',
            'tokenizer' => 'standard',
            'filter' => ['lowercase', 'custom_stop', 'porter_stem', 'asciifolding'],
          ],
          'wordcloud_analyzer' => [
            'type' => 'custom',
            'tokenizer' => 'standard',
            'filter' => ['lowercase', 'custom_stop', 'asciifolding'],
          ],
        ],
        'filter' => [
          'custom_stop' => [
            'type' => 'stop',
            'stopwords' => $stop_words,
          ],
        ],
      ],
    ];
    $logger->info('Prepared analyzer settings: @settings', ['@settings' => json_encode($settings)]);
    
    // Define field mapping to use custom analyzer.
    $mapping = [
      'properties' => [
        'answer_open_text' => [
          'type' => 'text',
          'analyzer' => 'custom_text_analyzer',
          'fields' => [
            'keyword' => [
              'type' => 'keyword',
              'ignore_above' => 256,
            ],
            'wordcloud' => [
              'type' => 'text',
              'analyzer' => 'wordcloud_analyzer',
              'fielddata' => TRUE,
            ],
          ],
        ],
      ],
    ];
    $logger->info('Prepared mapping: @mapping', ['@mapping' => json_encode($mapping)]);
    
    // Close index before updating settings.
    $logger->info('Closing index...');
    $close_response = $client->indices()->close(['index' => $index_name]);
    $logger->info('Index closed: @response', ['@response' => json_encode($close_response)]);
    
    // Update index settings.
    $logger->info('Updating settings...');
    $settings_response = $client->indices()->putSettings([
      'index' => $index_name,
      'body' => ['settings' => $settings],
    ]);
    $logger->info('Settings updated: @response', ['@response' => json_encode($settings_response)]);
    
    // Update field mapping.
    $logger->info('Updating mapping...');
    $mapping_response = $client->indices()->putMapping([
      'index' => $index_name,
      'body' => $mapping,
    ]);
    $logger->info('Mapping updated: @response', ['@response' => json_encode($mapping_response)]);
    
    // Reopen index.
    $logger->info('Reopening index...');
    $open_response = $client->indices()->open(['index' => $index_name]);
    $logger->info('Index reopened: @response', ['@response' => json_encode($open_response)]);
    
    // Verify the configuration was applied.
    try {
      $updated_settings = $client->indices()->getSettings(['index' => $index_name]);
      $logger->info('Updated index settings: @settings', ['@settings' => json_encode($updated_settings)]);
      
      $updated_mapping = $client->indices()->getMapping(['index' => $index_name]);
      $logger->info('Updated index mapping: @mapping', ['@mapping' => json_encode($updated_mapping)]);
    } catch (\Exception $e) {
      $logger->warning('Could not verify updated settings: @msg', ['@msg' => $e->getMessage()]);
    }
    
    $logger->info('=== Analyzer configuration completed successfully ===');
    
  } catch (\Exception $e) {
    $logger->error('!!! Failed to configure OpenSearch analyzer !!!');
    $logger->error('Exception class: @class', ['@class' => get_class($e)]);
    $logger->error('Exception message: @message', ['@message' => $e->getMessage()]);
    $logger->error('Exception trace: @trace', ['@trace' => $e->getTraceAsString()]);
  }
}

/**
 * Update OpenSearch analyzer configuration (callable from settings form).
 */
function open_science_survey_search_update_analyzer() {
  _open_science_survey_search_configure_analyzer();
}
