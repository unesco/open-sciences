# =============================================================================
# INVENIO CONFIGURATION (ordered alphabetically)
# =============================================================================

# Administrator email for system notifications
APP_RDM_ADMIN_EMAIL_RECIPIENT=info@unesco-science-portal.org

# Invenio API and base URLs
INVENIO_API_TOKEN=test_token_for_dry_run
INVENIO_BASE_URL=https://127.0.0.1:5000

# Secret key for Flask application (CHANGE THIS IN PRODUCTION!)
SECRET_KEY=CHANGE_ME

# API and UI URLs
SITE_API_URL=https://127.0.0.1/api
SITE_UI_URL=https://127.0.0.1

# Database connection string
SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://my-site:my-site@localhost/my-site

# =============================================================================
# DOCKER SERVICES CONFIGURATION (ordered alphabetically)
# =============================================================================

# OpenSearch configuration
OPENSEARCH_INITIAL_ADMIN_PASSWORD=guekxe3mvqieke1!%&ieIADE
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# PostgreSQL configuration
POSTGRES_DB=my-site
POSTGRES_PASSWORD=my-site
POSTGRES_USER=my-site

# pgAdmin configuration
PGADMIN_DEFAULT_EMAIL=info@my-site.com
PGADMIN_DEFAULT_PASSWORD=my-site

# RabbitMQ configuration
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_DEFAULT_USER=guest

# Redis configuration (default port, no password)
REDIS_HOST=cache
REDIS_PORT=6379

# =============================================================================
# TEST/PRODUCTION ADDITIONAL CREDENTIALS (not used in development)
# =============================================================================
# __NGINX_PASSWORD=your_nginx_password
# __NGINX_USER=staging
# __SUPERUSER=admin.unix@unesco.org
# __SUPERUSER_PASSWORD=your_superuser_password
# __URL=https://open-science-dev.unesco.org/%
